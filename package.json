{
  "name": "rei-launcher",
  "version": "1.0.0",
  "description": "Rei Launcher — A modern Minecraft launcher",
  "author": "Rei Launcher",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.reilauncher.app",
    "productName": "Rei Launcher",
    "directories": {
      "buildResources": "src/renderer/assets"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/renderer/assets/launcher_icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "axios": "^1.15.2",
    "ejs-electron": "^3.0.0",
    "electron-store": "^8.1.0",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
